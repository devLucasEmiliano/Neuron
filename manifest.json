{
  "manifest_version": 3,
  "name": "Neuron",
  "version": "2.0.0",
  "version_name": "2.00.2cccd",
  "description": "Otimizador de fluxos de trabalho na plataforma Fala.br",
  "author": "MAPA - DF",
  "icons": {
    "128": "images/icons/neuronon128.png"
  },
  "options_ui": {
    "page": "modules/options/options.html",
    "open_in_tab": true
  },
  "action": {
    "default_popup": "modules/popup/popup.html",
    "default_icon": {
      "128": "images/icons/neuronon128.png"
    }
  },
  "permissions": ["storage"],
  "host_permissions": [
    "https://falabr.cgu.gov.br/*",
    "https://treinafalabr.cgu.gov.br/*",
    "https://falabr-h.cgu.gov.br/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://falabr.cgu.gov.br/*",
        "https://treinafalabr.cgu.gov.br/*",
        "https://falabr-h.cgu.gov.br/*"
      ],
      "js": ["shared/js/neuron-db.js", "shared/js/neuron-sync.js", "modules/loading/loading.js"],
      "css": ["modules/loading/loading.css"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://falabr.cgu.gov.br/*",
        "https://treinafalabr.cgu.gov.br/*",
        "https://falabr-h.cgu.gov.br/*"
      ],
      "js": [
        "shared/js/neuron-utils.js",
        "modules/ouvidoria/tratar-novo/tratar-novo-extract.js",
        "modules/notificacoes/notificacoes.js"
      ],
      "css": ["modules/notificacoes/notificacoes.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://falabr.cgu.gov.br/Manifestacao/TratarManifestacoes",
        "https://treinafalabr.cgu.gov.br/Manifestacao/TratarManifestacoes",
        "https://falabr-h.cgu.gov.br/Manifestacao/TratarManifestacoes"
      ],
      "js": [
        "shared/js/neuron-utils.js",
        "shared/js/date-utils.js",
        "modules/ouvidoria/tratar-novo/tratar-novo-pagesize.js",
        "modules/ouvidoria/tratar-novo/tratar-novo-insert.js"
      ],
      "css": ["modules/ouvidoria/tratar-novo/tratar-novo.css"]
    },
    {
      "matches": [
        "https://falabr.cgu.gov.br/Manifestacao/ArquivarManifestacao.aspx?*",
        "https://treinafalabr.cgu.gov.br/Manifestacao/ArquivarManifestacao.aspx?*",
        "https://falabr-h.cgu.gov.br/Manifestacao/ArquivarManifestacao.aspx?*"
      ],
      "js": ["shared/js/module-factory.js", "modules/ouvidoria/arquivar/arquivar.js"],
      "css": ["modules/ouvidoria/arquivar/arquivar.css"]
    },
    {
      "matches": [
        "https://falabr.cgu.gov.br/Manifestacao/EncaminharManifestacao.aspx?*",
        "https://treinafalabr.cgu.gov.br/Manifestacao/EncaminharManifestacao.aspx?*",
        "https://falabr-h.cgu.gov.br/Manifestacao/EncaminharManifestacao.aspx?*"
      ],
      "js": ["shared/js/module-factory.js", "modules/ouvidoria/encaminhar/encaminhar.js"],
      "css": ["modules/ouvidoria/encaminhar/encaminhar.css"]
    },
    {
      "matches": [
        "https://falabr.cgu.gov.br/Manifestacao/ProrrogarManifestacao.aspx?*",
        "https://treinafalabr.cgu.gov.br/Manifestacao/ProrrogarManifestacao.aspx?*",
        "https://falabr-h.cgu.gov.br/Manifestacao/ProrrogarManifestacao.aspx?*"
      ],
      "js": ["shared/js/module-factory.js", "modules/ouvidoria/prorrogar/prorrogar.js"],
      "css": ["modules/ouvidoria/prorrogar/prorrogar.css"]
    },
    {
      "matches": [
        "https://falabr.cgu.gov.br/Manifestacao/TramitarManifestacao.aspx?*",
        "https://treinafalabr.cgu.gov.br/Manifestacao/TramitarManifestacao.aspx?*",
        "https://falabr-h.cgu.gov.br/Manifestacao/TramitarManifestacao.aspx?*"
      ],
      "js": [
        "shared/js/date-utils.js",
        "shared/js/module-factory.js",
        "modules/ouvidoria/tramitar/tramitar.js",
        "modules/ouvidoria/tramitar/tramitar-pontos-focais.js"
      ],
      "css": ["modules/ouvidoria/tramitar/tramitar.css"]
    },
    {
      "matches": [
        "https://falabr.cgu.gov.br/Manifestacao/TratarManifestacao.aspx?*",
        "https://treinafalabr.cgu.gov.br/Manifestacao/TratarManifestacao.aspx?*",
        "https://falabr-h.cgu.gov.br/Manifestacao/TratarManifestacao.aspx?*"
      ],
      "js": ["shared/js/module-factory.js", "modules/ouvidoria/tratar/tratar.js"],
      "css": ["modules/ouvidoria/tratar/tratar.css"]
    },
    {
      "matches": [
        "https://falabr.cgu.gov.br/web/manifestacao/analisar?ids=*",
        "https://treinafalabr.cgu.gov.br/web/manifestacao/analisar?ids=*",
        "https://falabr-h.cgu.gov.br/web/manifestacao/analisar?ids=*"
      ],
      "js": ["modules/ouvidoria/resposta/resposta.js"]
    },
    {
      "matches": [
        "https://falabr.cgu.gov.br/web/manifestacao/tratar?*",
        "https://treinafalabr.cgu.gov.br/web/manifestacao/tratar?*",
        "https://falabr-h.cgu.gov.br/web/manifestacao/tratar?*"
      ],
      "js": ["shared/js/date-utils.js", "modules/sic/tratar/sic-tratar-extract.js"],
      "css": ["modules/sic/tratar/sic-tratar-style.css"]
    },
    {
      "matches": [
        "https://falabr.cgu.gov.br/web/manifestacao/detalhar/*",
        "https://treinafalabr.cgu.gov.br/web/manifestacao/detalhar/*",
        "https://falabr-h.cgu.gov.br/web/manifestacao/detalhar/*"
      ],
      "js": ["modules/sic/analisar/sic-analisar-move-buttons.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "config/*",
        "images/*",
        "vendor/*",
        "vendor/bootstrap/*",
        "shared/js/*",
        "shared/css/*",
        "modules/loading/loading.html",
        "modules/options/options.html"
      ],
      "matches": [
        "https://falabr.cgu.gov.br/*",
        "https://treinafalabr.cgu.gov.br/*",
        "https://falabr-h.cgu.gov.br/*"
      ]
    }
  ]
}