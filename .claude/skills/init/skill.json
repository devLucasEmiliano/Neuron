{
  "name": "init",
  "version": "1.0.0",
  "description": "Development workflow orchestrator for Neuron Chrome Extension",
  "triggers": ["/init"],
  "config": {
    "trackedPaths": [
      "modules/**/*",
      "lib/**/*",
      "shared/**/*",
      "config/**/*",
      "manifest.json"
    ],
    "context7": {
      "maxQueriesPerRun": 9,
      "libraries": {
        "chromeExtensions": "/chrome/extensions",
        "bootstrap5": "/twbs/bootstrap/v5",
        "idb": "/jakearchibald/idb"
      }
    },
    "autoGenerate": {
      "confirmBeforeCreate": true
    },
    "autoSync": {
      "confirmBeforeUpdate": true
    }
  }
}
